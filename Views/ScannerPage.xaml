<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="EPMPolicyBuilder.Views.ScannerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:EPMPolicyBuilder.Views"
      xmlns:models="using:EPMPolicyBuilder.Models"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="1200" HorizontalAlignment="Left">

            <!-- Header -->
            <TextBlock Text="Drive Scanner" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Scan selected folders for installed applications and create elevation rules in bulk."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <!-- Scan Locations card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="16">
                <StackPanel Spacing="12">

                    <TextBlock Text="Scan Locations" Style="{StaticResource SubtitleTextBlockStyle}" />

                    <!-- Known folder checkboxes -->
                    <ItemsControl ItemsSource="{x:Bind ViewModel.ScanLocations, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VariableSizedWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4" ItemWidth="220" ItemHeight="36" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:ScanLocation">
                                <CheckBox Content="{x:Bind Name}"
                                          IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                          AutomationProperties.AutomationId="{x:Bind Name}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Custom folder row -->
                    <TextBlock Text="Custom Folder"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               Margin="0,4,0,0" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 IsReadOnly="True"
                                 PlaceholderText="Optional: browse to add a custom folder"
                                 Text="{x:Bind ViewModel.CustomScanPath, Mode=OneWay}" />
                        <Button Grid.Column="1"
                                Content="Browse…"
                                AutomationProperties.AutomationId="BrowseCustomFolderButton"
                                Click="BrowseCustomFolder_Click" />
                    </Grid>

                </StackPanel>
            </Border>

            <!-- Scan action row -->
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="Scan for Applications"
                        Style="{StaticResource AccentButtonStyle}"
                        AutomationProperties.AutomationId="ScanButton"
                        Command="{x:Bind ViewModel.ScanCommand}"
                        IsEnabled="{x:Bind local:ScannerPage.InvertBool(ViewModel.IsScanning), Mode=OneWay}" />
                <Button Content="Cancel"
                        AutomationProperties.AutomationId="CancelScanButton"
                        Command="{x:Bind ViewModel.CancelScanCommand}"
                        Visibility="{x:Bind local:ScannerPage.BoolToVisibility(ViewModel.IsScanning), Mode=OneWay}" />
                <ProgressBar IsIndeterminate="True"
                             Width="220"
                             VerticalAlignment="Center"
                             Visibility="{x:Bind local:ScannerPage.BoolToVisibility(ViewModel.IsScanning), Mode=OneWay}" />
            </StackPanel>

            <!-- Status text -->
            <TextBlock Text="{x:Bind ViewModel.ScanStatus, Mode=OneWay}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"
                       Visibility="{x:Bind local:ScannerPage.StatusToVisibility(ViewModel.ScanStatus), Mode=OneWay}" />

            <!-- Results card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="16"
                    Visibility="{x:Bind local:ScannerPage.BoolToVisibility(ViewModel.HasResults), Mode=OneWay}">
                <StackPanel Spacing="12">

                    <!-- Filter + selection controls -->
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 PlaceholderText="Filter by name, publisher, or path…"
                                 AutomationProperties.AutomationId="FilterTextBox"
                                 Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Content="Select All"
                                AutomationProperties.AutomationId="SelectAllButton"
                                Click="SelectAll_Click" />
                        <Button Grid.Column="2"
                                Content="Clear"
                                AutomationProperties.AutomationId="ClearSelectionButton"
                                Click="ClearSelection_Click" />
                        <TextBlock Grid.Column="3"
                                   VerticalAlignment="Center"
                                   Text="{x:Bind local:ScannerPage.SelectedText(ViewModel.SelectedCount), Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>

                    <!-- Results ListView -->
                    <ListView x:Name="ResultsList"
                              AutomationProperties.AutomationId="ScanResultsList"
                              ItemsSource="{x:Bind ViewModel.FilteredResults, Mode=OneWay}"
                              SelectionMode="Multiple"
                              SelectionChanged="ResultsList_SelectionChanged"
                              MaxHeight="520">

                        <!-- Column headers -->
                        <ListView.Header>
                            <Grid Padding="12,6" ColumnSpacing="8"
                                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="50" />
                                    <ColumnDefinition Width="110" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Name"
                                           Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="Path"
                                           Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2" Text="Publisher"
                                           Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="3" Text="Signed"
                                           Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="4" Text="Version"
                                           Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" />
                            </Grid>
                        </ListView.Header>

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="12,2" />
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ExeFileInfo">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="110" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind FileName}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTipService.ToolTip="{x:Bind FileName}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind FilePath}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               ToolTipService.ToolTip="{x:Bind FilePath}" />
                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind PublisherDisplay}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTipService.ToolTip="{x:Bind PublisherDisplay}" />
                                    <TextBlock Grid.Column="3"
                                               Text="{x:Bind SignedDisplay}"
                                               Foreground="{x:Bind local:ScannerPage.SignedBrush(IsSigned), Mode=OneWay}" />
                                    <TextBlock Grid.Column="4"
                                               Text="{x:Bind FileVersion}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>

                    </ListView>

                    <!-- Count summary -->
                    <TextBlock Text="{x:Bind local:ScannerPage.CountSummary(ViewModel.ScannedCount, ViewModel.SkippedFolderCount), Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="Open in Rule Builder"
                                AutomationProperties.AutomationId="SendToRuleBuilderButton"
                                Command="{x:Bind ViewModel.SendToRuleBuilderCommand}"
                                IsEnabled="{x:Bind local:ScannerPage.HasSelection(ViewModel.SelectedCount), Mode=OneWay}" />
                        <Button Content="Create Rules for Selected ? Upload"
                                Style="{StaticResource AccentButtonStyle}"
                                AutomationProperties.AutomationId="BatchCreateRulesButton"
                                Command="{x:Bind ViewModel.BatchCreateRulesCommand}"
                                IsEnabled="{x:Bind local:ScannerPage.HasSelection(ViewModel.SelectedCount), Mode=OneWay}" />
                    </StackPanel>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
