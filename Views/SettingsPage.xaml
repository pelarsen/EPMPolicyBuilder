<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="EPMPolicyBuilder.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:EPMPolicyBuilder.Views"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="20" MaxWidth="660" HorizontalAlignment="Left">

            <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Connect EPM Policy Builder to your Microsoft Intune tenant."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <!-- SECTION 1: Auto-register (no Azure CLI needed) -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="20">
                <StackPanel Spacing="14">

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE756;" FontSize="18"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock Text="Quick Setup — Create App Registration Automatically"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>

                    <TextBlock TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        Sign in as a <Bold>Global Admin</Bold> (or Application Administrator) and
                        the app will automatically register itself in your Azure AD tenant and
                        grant the required Intune permissions. No Azure CLI or PowerShell needed.
                    </TextBlock>

                    <!-- Not-yet-started state -->
                    <Button x:Name="CreateAppBtn"
                            Content="Sign In and Create App Registration"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.CreateAppRegistrationCommand}"
                            IsEnabled="{x:Bind local:SettingsPage.NotBusy(ViewModel.IsSetupRunning), Mode=OneWay}"
                            Visibility="{x:Bind local:SettingsPage.Hide(ViewModel.IsSetupComplete), Mode=OneWay}" />

                    <!-- Progress log (shown while running OR after error) -->
                    <StackPanel Spacing="8"
                                Visibility="{x:Bind local:SettingsPage.Show(ViewModel.IsSetupRunning), Mode=OneWay}">
                        <ProgressBar IsIndeterminate="True" />
                        <ListView x:Name="SetupLogList"
                                  ItemsSource="{x:Bind ViewModel.SetupLog}"
                                  SelectionMode="None"
                                  MinHeight="100"
                                  Background="{ThemeResource SystemFillColorSolidNeutralBackgroundBrush}"
                                  CornerRadius="{StaticResource ControlCornerRadius}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <TextBlock Text="{x:Bind}" FontFamily="Consolas" FontSize="12"
                                               TextWrapping="Wrap" Padding="4,2" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <!-- Error state: show log + error banner + retry button -->
                    <StackPanel Spacing="8"
                                Visibility="{x:Bind local:SettingsPage.Show(ViewModel.HasSetupError), Mode=OneWay}">
                        <ListView ItemsSource="{x:Bind ViewModel.SetupLog}"
                                  SelectionMode="None"
                                  MaxHeight="160"
                                  Background="{ThemeResource SystemFillColorSolidNeutralBackgroundBrush}"
                                  CornerRadius="{StaticResource ControlCornerRadius}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <TextBlock Text="{x:Bind}" FontFamily="Consolas" FontSize="12"
                                               TextWrapping="Wrap" Padding="4,2" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <InfoBar IsOpen="True" IsClosable="False" Severity="Error"
                                 Title="Setup failed"
                                 Message="{x:Bind ViewModel.SetupErrorMessage, Mode=OneWay}" />
                        <Button Content="Try Again"
                                Command="{x:Bind ViewModel.CreateAppRegistrationCommand}"
                                IsEnabled="{x:Bind local:SettingsPage.NotBusy(ViewModel.IsSetupRunning), Mode=OneWay}" />
                    </StackPanel>

                    <!-- Completed state -->
                    <StackPanel Spacing="10"
                                Visibility="{x:Bind local:SettingsPage.Show(ViewModel.IsSetupComplete), Mode=OneWay}">

                        <InfoBar IsOpen="True" IsClosable="False" Severity="Success"
                                 Title="App Registration Created"
                                 Message="The settings below have been saved automatically. Go to Intune Connection to sign in." />

                        <StackPanel Spacing="4">
                            <TextBlock Text="New Client ID" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox x:Name="NewClientIdBox"
                                         Text="{x:Bind ViewModel.NewClientId, Mode=OneWay}"
                                         IsReadOnly="True" FontFamily="Consolas" MinWidth="330" />
                                <Button Content="Copy" Click="CopyNewClientId_Click" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Setup Log" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ListView ItemsSource="{x:Bind ViewModel.SetupLog}"
                                      SelectionMode="None"
                                      MaxHeight="200"
                                      Background="{ThemeResource SystemFillColorSolidNeutralBackgroundBrush}"
                                      CornerRadius="{StaticResource ControlCornerRadius}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <TextBlock Text="{x:Bind}" FontFamily="Consolas" FontSize="12"
                                                   TextWrapping="Wrap" Padding="4,2" />
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>

                        <Button Content="Go to Intune Connection ?"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="GoToIntuneConnection_Click" />
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- SECTION 2: Manual configuration -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="20">
                <StackPanel Spacing="14">

                    <TextBlock Text="Manual Configuration"
                               Style="{StaticResource SubtitleTextBlockStyle}" />

                    <TextBlock TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        Already have an App Registration? Paste your Client ID here.
                        The app needs the <Bold>DeviceManagementConfiguration.ReadWrite.All</Bold>
                        delegated permission and a public-client redirect URI of
                        <Bold>https://login.microsoftonline.com/common/oauth2/nativeclient</Bold>.
                    </TextBlock>

                    <TextBox x:Name="ClientIdBox"
                             AutomationProperties.AutomationId="ClientIdTextBox"
                             Header="Application (Client) ID *"
                             PlaceholderText="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                             Text="{x:Bind ViewModel.ClientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox x:Name="TenantIdBox"
                             AutomationProperties.AutomationId="TenantIdTextBox"
                             Header="Directory (Tenant) ID  (leave blank or 'common' for any tenant)"
                             PlaceholderText="common"
                             Text="{x:Bind ViewModel.TenantId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="SaveButton"
                                AutomationProperties.AutomationId="SaveSettingsButton"
                                Content="Save Settings"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.SaveCommand}" />
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                    Visibility="{x:Bind local:SettingsPage.Show(ViewModel.IsSaved), Mode=OneWay}">
                            <FontIcon Glyph="&#xE73E;" Foreground="{ThemeResource SystemFillColorSuccessBrush}" FontSize="14" />
                            <TextBlock Text="Saved" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <HyperlinkButton Content="How to create an App Registration in Azure Portal ?"
                                     NavigateUri="https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps/CreateApplicationBlade" />

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
