<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="EPMPolicyBuilder.Views.FileAnalysisPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:EPMPolicyBuilder.Views"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="860" HorizontalAlignment="Left">

            <!-- Header -->
            <TextBlock Text="File Analysis" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Browse or scan a file to extract metadata for use in an EPM elevation rule."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <!-- File picker card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Select File" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Supported types: .exe, .msi, .ps1"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="FilePathBox"
                                 AutomationProperties.AutomationId="FilePathTextBox"
                                 Grid.Column="0"
                                 PlaceholderText="Select a file to analyze..."
                                 Text="{x:Bind ViewModel.SelectedFilePath, Mode=OneWay}"
                                 IsReadOnly="True" />
                        <Button x:Name="BrowseButton"
                                AutomationProperties.AutomationId="BrowseFileButton"
                                Grid.Column="1"
                                Content="Browse..."
                                Click="BrowseButton_Click" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Status / loading -->
            <ProgressRing x:Name="LoadingRing"
                          IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Visibility="{x:Bind local:FileAnalysisPage.BoolToVisibility(ViewModel.IsLoading), Mode=OneWay}"
                          Width="32" Height="32" />

            <InfoBar x:Name="StatusInfoBar"
                     AutomationProperties.AutomationId="AnalysisStatusInfoBar"
                     IsOpen="{x:Bind local:FileAnalysisPage.HasStatus(ViewModel.StatusMessage), Mode=OneWay}"
                     Severity="{x:Bind local:FileAnalysisPage.StatusSeverity(ViewModel.HasError), Mode=OneWay}"
                     Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                     IsClosable="True" />

            <!-- Metadata card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="16"
                    Visibility="{x:Bind local:FileAnalysisPage.BoolToVisibility(ViewModel.HasFileMetadata), Mode=OneWay}">
                <StackPanel Spacing="12">
                    <TextBlock Text="File Metadata" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <Grid ColumnSpacing="16" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="File Name" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.FileMetadata.FileName, Mode=OneWay}" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="File Path" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.FileMetadata.FilePath, Mode=OneWay}" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="SHA256 Hash" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.FileMetadata.FileHash, Mode=OneWay}" TextWrapping="Wrap" FontFamily="Consolas" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Product Name" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.FileMetadata.ProductName, Mode=OneWay}" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Internal Name" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{x:Bind ViewModel.FileMetadata.InternalName, Mode=OneWay}" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="File Version" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{x:Bind ViewModel.FileMetadata.FileVersion, Mode=OneWay}" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="File Description" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{x:Bind ViewModel.FileMetadata.FileDescription, Mode=OneWay}" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Publisher" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{x:Bind ViewModel.FileMetadata.PublisherName, Mode=OneWay}" TextWrapping="Wrap" />
                    </Grid>

                    <Button x:Name="UseInRuleButton"
                            AutomationProperties.AutomationId="UseInRuleButton"
                            Content="Use This File in Rule Builder â†’"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="UseInRuleButton_Click" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
