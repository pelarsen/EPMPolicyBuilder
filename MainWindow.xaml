<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="EPMPolicyBuilder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:EPMPolicyBuilder"
        Title="EPM Policy Builder">

    <Grid>
        <NavigationView x:Name="NavView"
                        AutomationProperties.AutomationId="MainNavigationView"
                        IsSettingsVisible="True"
                        IsBackButtonVisible="Collapsed"
                        SelectionChanged="NavView_SelectionChanged"
                        Loaded="NavView_Loaded">

            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="FileAnalysisNavItem"
                                    AutomationProperties.AutomationId="FileAnalysisNavItem"
                                    Content="File Analysis"
                                    Tag="FileAnalysis">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8A5;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="RuleBuilderNavItem"
                                    AutomationProperties.AutomationId="RuleBuilderNavItem"
                                    Content="Rule Builder"
                                    Tag="RuleBuilder">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="ScannerNavItem"
                                    AutomationProperties.AutomationId="ScannerNavItem"
                                    Content="Drive Scanner"
                                    Tag="Scanner">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE74C;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="SuggestionsNavItem"
                                    AutomationProperties.AutomationId="SuggestionsNavItem"
                                    Content="Rule Suggestions"
                                    Tag="Suggestions">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE82F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="IntuneConnectionNavItem"
                                    AutomationProperties.AutomationId="IntuneConnectionNavItem"
                                    Content="Certificates"
                                    Tag="IntuneConnection">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8C5;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="PolicyUploadNavItem"
                                    AutomationProperties.AutomationId="PolicyUploadNavItem"
                                    Content="Policy Upload"
                                    Tag="PolicyUpload">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE898;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <!-- ── Connection status footer ─────────────────────────── -->
            <NavigationView.PaneFooter>
                <StackPanel Padding="8,0,8,16" Spacing="8">

                    <!-- Connected: user chip + disconnect -->
                    <StackPanel Spacing="6"
                                Visibility="{x:Bind local:MainWindow.BoolToVisibility(ConnectionVm.IsConnected), Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="10" Padding="4,4">
                            <FontIcon Glyph="&#xE73E;" FontSize="14"
                                      Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                      VerticalAlignment="Center" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind ConnectionVm.ConnectedUser, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="148" />
                                <TextBlock Text="Connected to Intune"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                        <Button Content="Disconnect"
                                Command="{x:Bind ConnectionVm.DisconnectCommand}"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <!-- Not connected: connect button -->
                    <StackPanel Spacing="6"
                                Visibility="{x:Bind local:MainWindow.InvertBoolToVisibility(ConnectionVm.IsConnected), Mode=OneWay}">
                        <Button Content="Connect to Intune"
                                Command="{x:Bind ConnectionVm.ConnectCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch"
                                IsEnabled="{x:Bind local:MainWindow.InvertBool(ConnectionVm.IsLoading), Mode=OneWay}" />
                        <ProgressBar IsIndeterminate="True"
                                     Visibility="{x:Bind local:MainWindow.BoolToVisibility(ConnectionVm.IsLoading), Mode=OneWay}" />
                        <!-- Connection error hint (e.g. no ClientId, AADSTS50011) -->
                        <TextBlock Text="{x:Bind ConnectionVm.StatusMessage, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                   TextWrapping="Wrap"
                                   MaxWidth="180"
                                   Visibility="{x:Bind local:MainWindow.BoolToVisibility(ConnectionVm.HasError), Mode=OneWay}" />
                    </StackPanel>

                </StackPanel>
            </NavigationView.PaneFooter>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
