<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1' x:Class="EPMPolicyBuilder.Views.IntuneConnectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:EPMPolicyBuilder.Views"
      xmlns:models="using:EPMPolicyBuilder.Models"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="860" HorizontalAlignment="Left">

            <TextBlock Text="Certificates" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="View and manage reusable certificate settings for EPM elevation rules."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <!-- Redirect URI fix banner -->
            <InfoBar x:ConnectionId='2' x:Name="RedirectUriInfoBar"
                                                                                 
                     IsClosable="False"
                     Severity="Warning"
                     Title="Redirect URI not registered (AADSTS50011)"
                                                                                                                                  >
                <InfoBar.Content>
                    <StackPanel Spacing="8" Margin="0,8,0,4">
                        <TextBlock TextWrapping="Wrap">
                            The app registration is missing <Bold>http://localhost</Bold> as a redirect URI.
                            Click below to fix it automatically (requires signing in as Global Admin again).
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:ConnectionId='29' Content="Fix Redirect URI Automatically"
                                    Style="{StaticResource AccentButtonStyle}"
                                                                                      
                                                                                                                                        />
                            <HyperlinkButton Content="Fix manually in Azure Portal â†’"
                                             NavigateUri="https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps/ApplicationsListBlade" />
                        </StackPanel>
                        <ProgressBar x:ConnectionId='28' IsIndeterminate="True"
                                                                                                                                                   />
                    </StackPanel>
                </InfoBar.Content>
            </InfoBar>

            <!-- No client ID warning â€“ with wizard shortcut -->
            <InfoBar x:ConnectionId='3' x:Name="NoClientIdInfoBar"
                     AutomationProperties.AutomationId="NoClientIdInfoBar"
                                                                                                                
                     IsClosable="False"
                     Severity="Warning"
                     Title="Azure AD App Not Configured">
                <InfoBar.Content>
                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,4">
                        <TextBlock Text="No App Registration is saved yet."
                                   VerticalAlignment="Center" />
                        <Button x:ConnectionId='27' Content="Go to Settings â†’"
                                Style="{StaticResource AccentButtonStyle}"
                                                                />
                    </StackPanel>
                </InfoBar.Content>
            </InfoBar>

            <!-- Status InfoBar -->
            <InfoBar x:ConnectionId='4' x:Name="StatusInfoBar"
                     AutomationProperties.AutomationId="ConnectionStatusInfoBar"
                                                                                                                 
                                                                                                                   
                                                                            
                     IsClosable="True" />

            <!-- Reusable settings card -->
            <Border x:ConnectionId='5' Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="16"
                                                                                                                         >
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Reusable Certificate Settings" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button x:ConnectionId='25' x:Name="RefreshCertsButton"
                                    AutomationProperties.AutomationId="RefreshCertsButton"
                                    Content="Refresh"
                                                                                             />
                            <Button x:ConnectionId='26' x:Name="UploadCertButton"
                                    AutomationProperties.AutomationId="UploadCertButton"
                                    Content="Upload New Certificate"
                                    Style="{StaticResource AccentButtonStyle}"
                                                                   />
                        </StackPanel>
                    </Grid>

                    <ListView x:ConnectionId='6' x:Name="ReusableSettingsList"
                              AutomationProperties.AutomationId="ReusableSettingsList"
                                                                               
                              SelectionMode="None"
                              MinHeight="80">
                        <ListView.ItemTemplate>
                            <DataTemplate                                    >
                                <Border x:ConnectionId='8' Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1" CornerRadius="4"
                                        Padding="16,12" Margin="0,4">
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Certificate icon -->
                                        <Border Grid.Column="0"
                                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="6" Width="40" Height="40"
                                                VerticalAlignment="Top">
                                            <FontIcon Glyph="&#xE8C5;" FontSize="20" Foreground="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>

                                        <!-- Main content -->
                                        <StackPanel Grid.Column="1" Spacing="6">
                                            <!-- Name + description -->
                                            <TextBlock x:ConnectionId='15'                            
                                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <TextBlock x:ConnectionId='16'                            
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                                                                                        />

                                            <!-- X.509 details grid -->
                                            <Grid x:ConnectionId='17' ColumnSpacing="24" RowSpacing="4"
                                                                                                                                >
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition />
                                                    <RowDefinition />
                                                </Grid.RowDefinitions>

                                                <!-- Row 0: Subject, Issuer -->
                                                <StackPanel Grid.Column="0" Grid.Row="0" Spacing="2">
                                                    <TextBlock Text="Subject" Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    <TextBlock x:ConnectionId='24'                            
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                               MaxWidth="220" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Grid.Row="0" Spacing="2">
                                                    <TextBlock Text="Issuer" Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    <TextBlock x:ConnectionId='23'                           
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                               MaxWidth="220" />
                                                </StackPanel>

                                                <!-- Row 1: Valid From, Thumbprint -->
                                                <StackPanel Grid.Column="0" Grid.Row="1" Spacing="2">
                                                    <TextBlock Text="Valid from" Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    <TextBlock x:ConnectionId='22'                               
                                                               Style="{StaticResource CaptionTextBlockStyle}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Grid.Row="1" Spacing="2">
                                                    <TextBlock Text="Thumbprint" Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    <TextBlock x:ConnectionId='21'                                
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               FontFamily="Cascadia Code, Consolas, monospace" />
                                                </StackPanel>
                                            </Grid>

                                            <!-- Uploaded date -->
                                            <TextBlock x:ConnectionId='18' Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                                                                                        >
                                                <Run Text="Uploaded " />
                                                <Run x:ConnectionId='20'                              />
                                            </TextBlock>

                                            <!-- ID (small) -->
                                            <TextBlock x:ConnectionId='19'                   
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <!-- Expiry badge (right column) -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Top" Spacing="4">
                                            <!-- Expired badge -->
                                            <Border x:ConnectionId='9' Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                                                    BorderBrush="{ThemeResource SystemFillColorCriticalBrush}"
                                                    BorderThickness="1" CornerRadius="4" Padding="8,4"
                                                                                                                                >
                                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                                    <TextBlock Text="EXPIRED" Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                               FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                    <TextBlock x:ConnectionId='14'                            
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                               HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                            <!-- Expiring soon badge -->
                                            <Border x:ConnectionId='10' Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                                                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}"
                                                    BorderThickness="1" CornerRadius="4" Padding="8,4"
                                                                                                                                  >
                                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                                    <TextBlock Text="EXPIRES SOON" Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                               FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                    <TextBlock x:ConnectionId='13'                            
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                               HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                            <!-- Valid badge -->
                                            <Border x:ConnectionId='11' Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                                    BorderBrush="{ThemeResource SystemFillColorSuccessBrush}"
                                                    BorderThickness="1" CornerRadius="4" Padding="8,4"
                                                                                                                                                              >
                                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                                    <TextBlock Text="VALID" Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                                               FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                    <TextBlock x:ConnectionId='12'                            
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                                               HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

