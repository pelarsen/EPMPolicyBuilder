<?xml version="1.0" encoding="utf-8"?>
<Window x:ConnectionId='1' x:Class="EPMPolicyBuilder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:EPMPolicyBuilder"
        Title="EPM Policy Builder">

    <Grid>
        <NavigationView x:ConnectionId='2' x:Name="NavView"
                        AutomationProperties.AutomationId="MainNavigationView"
                        IsSettingsVisible="True"
                        IsBackButtonVisible="Collapsed"
                                                                   
                                               >

            <NavigationView.MenuItems>
                <NavigationViewItem x:ConnectionId='3' x:Name="FileAnalysisNavItem"
                                    AutomationProperties.AutomationId="FileAnalysisNavItem"
                                    Content="File Analysis"
                                    Tag="FileAnalysis">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8A5;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:ConnectionId='4' x:Name="RuleBuilderNavItem"
                                    AutomationProperties.AutomationId="RuleBuilderNavItem"
                                    Content="Rule Builder"
                                    Tag="RuleBuilder">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:ConnectionId='5' x:Name="ScannerNavItem"
                                    AutomationProperties.AutomationId="ScannerNavItem"
                                    Content="Drive Scanner"
                                    Tag="Scanner">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE74C;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:ConnectionId='6' x:Name="SuggestionsNavItem"
                                    AutomationProperties.AutomationId="SuggestionsNavItem"
                                    Content="Rule Suggestions"
                                    Tag="Suggestions">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE82F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:ConnectionId='7' x:Name="IntuneConnectionNavItem"
                                    AutomationProperties.AutomationId="IntuneConnectionNavItem"
                                    Content="Certificates"
                                    Tag="IntuneConnection">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8C5;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:ConnectionId='8' x:Name="PolicyUploadNavItem"
                                    AutomationProperties.AutomationId="PolicyUploadNavItem"
                                    Content="Policy Upload"
                                    Tag="PolicyUpload">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE898;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <!-- ── Connection status footer ─────────────────────────── -->
            <NavigationView.PaneFooter>
                <StackPanel Padding="8,0,8,16" Spacing="8">

                    <!-- Connected: user chip + disconnect -->
                    <StackPanel x:ConnectionId='9' Spacing="6"
                                                                                                                              >
                        <StackPanel Orientation="Horizontal" Spacing="10" Padding="4,4">
                            <FontIcon Glyph="&#xE73E;" FontSize="14"
                                      Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                      VerticalAlignment="Center" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:ConnectionId='15'                                                        
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="148" />
                                <TextBlock Text="Connected to Intune"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                        <Button x:ConnectionId='14' Content="Disconnect"
                                                                                 
                                HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <!-- Not connected: connect button -->
                    <StackPanel x:ConnectionId='10' Spacing="6"
                                                                                                                                    >
                        <Button x:ConnectionId='11' Content="Connect to Intune"
                                                                              
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch"
                                                                                                                      />
                        <ProgressBar x:ConnectionId='12' IsIndeterminate="True"
                                                                                                                                  />
                        <!-- Connection error hint (e.g. no ClientId, AADSTS50011) -->
                        <TextBlock x:ConnectionId='13'                                                        
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                   TextWrapping="Wrap"
                                   MaxWidth="180"
                                                                                                                               />
                    </StackPanel>

                </StackPanel>
            </NavigationView.PaneFooter>

            <Frame x:ConnectionId='16' x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>

