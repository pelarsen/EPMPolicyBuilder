<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1' x:Class="EPMPolicyBuilder.Views.ScannerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:EPMPolicyBuilder.Views"
      xmlns:models="using:EPMPolicyBuilder.Models"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="1200" HorizontalAlignment="Left">

            <!-- Header -->
            <TextBlock Text="Drive Scanner" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Scan selected folders for installed applications and create elevation rules in bulk."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <!-- Scan Locations card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="16">
                <StackPanel Spacing="12">

                    <TextBlock Text="Scan Locations" Style="{StaticResource SubtitleTextBlockStyle}" />

                    <!-- Known folder checkboxes -->
                    <ItemsControl x:ConnectionId='22'                                                            >
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VariableSizedWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4" ItemWidth="220" ItemHeight="36" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate                                 >
                                <CheckBox x:ConnectionId='26'                        
                                                                                      
                                                                                            />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Custom folder row -->
                    <TextBlock Text="Custom Folder"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               Margin="0,4,0,0" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:ConnectionId='23' Grid.Column="0"
                                 IsReadOnly="True"
                                 PlaceholderText="Optional: browse to add a custom folder"
                                                                                       />
                        <Button x:ConnectionId='24' Grid.Column="1"
                                Content="Browse…"
                                AutomationProperties.AutomationId="BrowseCustomFolderButton"
                                                                 />
                    </Grid>

                </StackPanel>
            </Border>

            <!-- Scan action row -->
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button x:ConnectionId='19' Content="Scan for Applications"
                        Style="{StaticResource AccentButtonStyle}"
                        AutomationProperties.AutomationId="ScanButton"
                                                                
                                                                                                             />
                <Button x:ConnectionId='20' Content="Cancel"
                        AutomationProperties.AutomationId="CancelScanButton"
                                                                      
                                                                                                                    />
                <ProgressBar x:ConnectionId='21' IsIndeterminate="True"
                             Width="220"
                             VerticalAlignment="Center"
                                                                                                                         />
            </StackPanel>

            <!-- Status text -->
            <TextBlock x:ConnectionId='2'                                                  
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"
                                                                                                                     />

            <!-- Results card -->
            <Border x:ConnectionId='3' Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="16"
                                                                                                               >
                <StackPanel Spacing="12">

                    <!-- Filter + selection controls -->
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:ConnectionId='15' Grid.Column="0"
                                 PlaceholderText="Filter by name, publisher, or path…"
                                 AutomationProperties.AutomationId="FilterTextBox"
                                                                                                                        />
                        <Button x:ConnectionId='16' Grid.Column="1"
                                Content="Select All"
                                AutomationProperties.AutomationId="SelectAllButton"
                                                        />
                        <Button x:ConnectionId='17' Grid.Column="2"
                                Content="Clear"
                                AutomationProperties.AutomationId="ClearSelectionButton"
                                                             />
                        <TextBlock x:ConnectionId='18' Grid.Column="3"
                                   VerticalAlignment="Center"
                                                                                                                       
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>

                    <!-- Results ListView -->
                    <ListView x:ConnectionId='4' x:Name="ResultsList"
                              AutomationProperties.AutomationId="ScanResultsList"
                                                                                           
                              SelectionMode="Multiple"
                                                                             
                              MaxHeight="520">

                        <!-- Column headers -->
                        <ListView.Header>
                            <Grid Padding="12,6" ColumnSpacing="8"
                                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="50" />
                                    <ColumnDefinition Width="110" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Name"
                                           Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="Path"
                                           Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2" Text="Publisher"
                                           Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="3" Text="Signed"
                                           Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="4" Text="Version"
                                           Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" />
                            </Grid>
                        </ListView.Header>

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="12,2" />
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate                                >
                                <Grid x:ConnectionId='9' ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="110" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:ConnectionId='10' Grid.Column="0"
                                                                       
                                               TextTrimming="CharacterEllipsis"
                                                                                          />
                                    <TextBlock x:ConnectionId='11' Grid.Column="1"
                                                                       
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                                          />
                                    <TextBlock x:ConnectionId='12' Grid.Column="2"
                                                                               
                                               TextTrimming="CharacterEllipsis"
                                                                                                  />
                                    <TextBlock x:ConnectionId='13' Grid.Column="3"
                                                                            
                                                                                                                          />
                                    <TextBlock x:ConnectionId='14' Grid.Column="4"
                                                                          
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>

                    </ListView>

                    <!-- Count summary -->
                    <TextBlock x:ConnectionId='5'                                                                                                                  
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button x:ConnectionId='6' Content="Open in Rule Builder"
                                AutomationProperties.AutomationId="SendToRuleBuilderButton"
                                                                                     
                                                                                                                          />
                        <Button x:ConnectionId='7' Content="Create Rules for Selected ? Upload"
                                Style="{StaticResource AccentButtonStyle}"
                                AutomationProperties.AutomationId="BatchCreateRulesButton"
                                                                                    
                                                                                                                          />
                    </StackPanel>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

