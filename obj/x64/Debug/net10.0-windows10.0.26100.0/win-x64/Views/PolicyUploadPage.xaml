<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1' x:Class="EPMPolicyBuilder.Views.PolicyUploadPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:EPMPolicyBuilder.Views"
      xmlns:models="using:EPMPolicyBuilder.Models"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="860" HorizontalAlignment="Left">

            <TextBlock Text="Policy Upload" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Review the generated rule JSON and upload it to Microsoft Intune."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <!-- Not connected â€” inline connect card -->
            <Border x:ConnectionId='2' Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="20"
                                                                                                                           >
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <FontIcon Glyph="&#xEA8A;" FontSize="32"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  VerticalAlignment="Center" />
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Connect to Microsoft Intune"
                                       Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock Text="Sign in to load EPM policies and upload elevation rules."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>

                    <ProgressBar x:ConnectionId='20' IsIndeterminate="True"
                                                                                                                                    />

                    <!-- Show connection errors (e.g. AADSTS50011) inline -->
                    <InfoBar x:ConnectionId='21'                                                                                                   
                             IsClosable="False"
                             Severity="Error"
                                                                                               />

                    <Button x:ConnectionId='22' Content="Connect to Intune"
                            Style="{StaticResource AccentButtonStyle}"
                                                                       
                                                                                                                        />
                </StackPanel>
            </Border>

            <!-- Batch upload banner -->
            <InfoBar x:ConnectionId='3' x:Name="BatchModeInfoBar"
                     AutomationProperties.AutomationId="BatchModeInfoBar"
                                                                         
                     IsClosable="False"
                     Severity="Informational"
                     Title="Batch Upload Mode"
                                                                            />

            <!-- No rule warning -->
            <InfoBar x:ConnectionId='4' x:Name="NoRuleInfoBar"
                     AutomationProperties.AutomationId="NoRuleInfoBar"
                                                                                                        
                     IsClosable="False"
                     Severity="Informational"
                     Title="No Rule Configured"
                     Message="Build a rule in the Rule Builder page first, then return here to upload it." />

            <!-- Rule JSON preview -->
            <Border x:ConnectionId='5' Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="16"
                                                                                                                 >
                <StackPanel Spacing="12">
                    <TextBlock Text="Rule JSON Preview" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <ScrollViewer MaxHeight="320" HorizontalScrollBarVisibility="Auto">
                        <TextBlock x:ConnectionId='19' x:Name="RuleJsonPreview"
                                                                                  
                                   FontFamily="Consolas"
                                   TextWrapping="Wrap" />
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Policy target card -->
            <Border x:ConnectionId='6' Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="16"
                                                                                                                     >
                <StackPanel Spacing="12">
                    <TextBlock Text="Target Policy" Style="{StaticResource SubtitleTextBlockStyle}" />

                    <RadioButtons x:ConnectionId='12' x:Name="PolicyTargetRadio"                                                      >
                        <RadioButton x:ConnectionId='17' x:Name="ExistingPolicyRadio"
                                     AutomationProperties.AutomationId="ExistingPolicyRadio"
                                     Content="Add to Existing Policy" IsChecked="True" />
                        <RadioButton x:ConnectionId='18' x:Name="NewPolicyRadio"
                                     AutomationProperties.AutomationId="NewPolicyRadio"
                                     Content="Create New Policy" />
                    </RadioButtons>

                    <!-- Existing policy selector -->
                    <StackPanel x:ConnectionId='13' Spacing="8"
                                                                                                                                           >
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:ConnectionId='15' x:Name="PolicyComboBox"
                                      AutomationProperties.AutomationId="ExistingPoliciesComboBox"
                                      Grid.Column="0"
                                      Header="Select EPM Policy"
                                                                               
                                                                                                   
                                      DisplayMemberPath="Name"
                                      HorizontalAlignment="Stretch" />
                            <Button x:ConnectionId='16' x:Name="LoadPoliciesButton"
                                    AutomationProperties.AutomationId="LoadPoliciesButton"
                                    Grid.Column="1"
                                    Content="Refresh"
                                    VerticalAlignment="Bottom"
                                                                                     />
                        </Grid>
                    </StackPanel>

                    <!-- New policy name -->
                    <TextBox x:ConnectionId='14' x:Name="NewPolicyNameBox"
                             AutomationProperties.AutomationId="NewPolicyNameTextBox"
                             Header="New Policy Name"
                             PlaceholderText="e.g., EPM Elevation Rules - Finance"
                                                                                                                      
                                                                                                                                   />
                </StackPanel>
            </Border>

            <!-- Upload button + status -->
            <Button x:ConnectionId='7' x:Name="UploadButton"
                    AutomationProperties.AutomationId="UploadRuleButton"
                    Content="Upload Rule to Intune"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Right"
                                                                                                                                                     
                                                               />

            <ProgressBar x:ConnectionId='8' x:Name="UploadProgressBar"
                         IsIndeterminate="True"
                                                                                                                         />

            <InfoBar x:ConnectionId='9' x:Name="UploadStatusInfoBar"
                     AutomationProperties.AutomationId="UploadStatusInfoBar"
                                                                                                             
                                                                                                                                     
                                                                            
                     IsClosable="True" />

            <!-- Actual request JSON sent to Graph â€” only shown on upload errors -->
            <Border x:ConnectionId='10' Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource SystemFillColorCriticalBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="16"
                                                                                                                      >
                <StackPanel Spacing="8">
                    <TextBlock Text="Request JSON sent to Graph API"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                    <ScrollViewer MaxHeight="320" HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <TextBlock x:ConnectionId='11'                                                        
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                    </ScrollViewer>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

