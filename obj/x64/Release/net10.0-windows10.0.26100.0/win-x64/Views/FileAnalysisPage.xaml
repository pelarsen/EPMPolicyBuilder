<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1' x:Class="EPMPolicyBuilder.Views.FileAnalysisPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:EPMPolicyBuilder.Views"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="860" HorizontalAlignment="Left">

            <!-- Header -->
            <TextBlock Text="File Analysis" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Browse or scan a file to extract metadata for use in an EPM elevation rule."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <!-- File picker card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Select File" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Supported types: .exe, .msi, .ps1"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:ConnectionId='14' x:Name="FilePathBox"
                                 AutomationProperties.AutomationId="FilePathTextBox"
                                 Grid.Column="0"
                                 PlaceholderText="Select a file to analyze..."
                                                                                        
                                 IsReadOnly="True" />
                        <Button x:ConnectionId='15' x:Name="BrowseButton"
                                AutomationProperties.AutomationId="BrowseFileButton"
                                Grid.Column="1"
                                Content="Browse..."
                                                           />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Status / loading -->
            <ProgressRing x:ConnectionId='2' x:Name="LoadingRing"
                                                                              
                                                                                                                         
                          Width="32" Height="32" />

            <InfoBar x:ConnectionId='3' x:Name="StatusInfoBar"
                     AutomationProperties.AutomationId="AnalysisStatusInfoBar"
                                                                                                             
                                                                                                               
                                                                            
                     IsClosable="True" />

            <!-- Metadata card -->
            <Border x:ConnectionId='4' Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="16"
                                                                                                                         >
                <StackPanel Spacing="12">
                    <TextBlock Text="File Metadata" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <Grid ColumnSpacing="16" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="File Name" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:ConnectionId='6' Grid.Row="0" Grid.Column="1"                                                              TextWrapping="Wrap" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="File Path" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:ConnectionId='7' Grid.Row="1" Grid.Column="1"                                                              TextWrapping="Wrap" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="SHA256 Hash" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:ConnectionId='8' Grid.Row="2" Grid.Column="1"                                                              TextWrapping="Wrap" FontFamily="Consolas" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Product Name" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:ConnectionId='9' Grid.Row="3" Grid.Column="1"                                                                 TextWrapping="Wrap" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Internal Name" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:ConnectionId='10' Grid.Row="4" Grid.Column="1"                                                                  TextWrapping="Wrap" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="File Version" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:ConnectionId='11' Grid.Row="5" Grid.Column="1"                                                                 TextWrapping="Wrap" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="File Description" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:ConnectionId='12' Grid.Row="6" Grid.Column="1"                                                                     TextWrapping="Wrap" />

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Publisher" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:ConnectionId='13' Grid.Row="7" Grid.Column="1"                                                                   TextWrapping="Wrap" />
                    </Grid>

                    <Button x:ConnectionId='5' x:Name="UseInRuleButton"
                            AutomationProperties.AutomationId="UseInRuleButton"
                            Content="Use This File in Rule Builder â†’"
                            Style="{StaticResource AccentButtonStyle}"
                                                          />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

